<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("partials/head", { pageTitle: (title || "Error") + " | ResearchHub" }) %>
</head>

<body>

    <%- include("partials/navbar") %>

    <section class="error-section d-flex align-items-center">

        <div class="container text-center reveal">

            <div class="error-emoji mb-3">🧭</div>

            <h1 class="fw-bold mb-3"><%= title || "Something Went Wrong" %></h1>

            <p class="lead text-muted mb-4">
                <%= message || "Please try again later." %>
            </p>

            <a href="/" class="btn btn-gradient btn-lg">
                ⬅ Back to Home
            </a>

        </div>

    </section>

    <%- include("partials/footer") %>

    <%- include("partials/scripts") %>

</body>
</html>

<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Student Dashboard | ResearchHub</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <link rel="stylesheet" href="/css/style.css">

</head>

<body>

    <!-- NAVBAR -->

    <%- include("partials/navbar") %>

    <div class="container mt-5 mb-5">

        <!-- Welcome Banner -->

        <div class="p-5 rounded-4 shadow-sm text-white mb-5"
            style="background:linear-gradient(135deg,#064E3B,#0F766E,#14B8A6);">

            <h1 class="fw-bold">
                Welcome, <%= user.fullName %> 👋
            </h1>

            <p class="fs-5 mt-3 mb-1">
                <strong>Department:</strong>
                <%= user.department %>
            </p>

            <p class="fs-5">
                <strong>Degree:</strong>
                <%= user.degreeLevel %>
            </p>

            <p class="mb-0">
                Manage your uploaded research and contribute to the university repository.
            </p>

        </div>

        <!-- Summary Cards -->

        <div class="row g-4 mb-5">

            <div class="col-md-4">

                <div class="card dashboard-card text-center p-4">

                    <h2 class="text-primary fw-bold">
                        <%= researches.length %>
                    </h2>

                    <h5>My Research</h5>

                </div>

            </div>

            <div class="col-md-4">

                <div class="card dashboard-card text-center p-4">

                    <h4 class="text-success fw-bold">
                        <%= user.department %>
                    </h4>

                    <h5>Department</h5>

                </div>

            </div>

            <div class="col-md-4">

                <div class="card dashboard-card text-center p-4">

                    <h4 class="text-warning fw-bold">
                        <%= user.degreeLevel %>
                    </h4>

                    <h5>Degree Level</h5>

                </div>

            </div>

        </div>

        <!-- Buttons -->

        <div class="mb-5">

            <a href="/upload-research" class="btn btn-warning btn-lg me-3">
                📤 Upload Research
            </a>

            <a href="/researches" class="btn btn-success btn-lg">
                📚 Browse Repository
            </a>

        </div>

        <hr class="mb-5">

        <!-- Uploaded Research -->

        <h3 class="fw-bold text-success mb-4">

            📚 My Uploaded Research

        </h3>

        <% if(researches.length===0){ %>

            <div class="alert alert-info">

                You haven't uploaded any research yet.

            </div>

        <% } else { %>

            <div class="row">

                <% researches.forEach(research => { %>

                    <div class="col-lg-6 mb-4">

                        <div class="card dashboard-card h-100">

                            <div class="card-body">

                                <h4 class="fw-bold">

                                    <%= research.title %>

                                </h4>

                                <p class="text-muted">

                                    <%= research.department %> • <%= research.degreeLevel %>

                                </p>

                                <p>

                                    <strong>Student:</strong>

                                    <%= research.studentName %>

                                </p>

                                <p>

                                    <strong>Supervisor:</strong>

                                    <%= research.supervisor %>

                                </p>

                                <p>

                                    <strong>Year:</strong>

                                    <%= research.year %>

                                </p>

                                <hr>

                                <div class="d-flex gap-2 flex-wrap">

                                    <a href="/uploads/<%= research.pdfFile %>"
                                        target="_blank"
                                        class="btn btn-success btn-sm">

                                        View PDF

                                    </a>

                                    <a href="/edit-research/<%= research._id %>"
                                        class="btn btn-warning btn-sm">

                                        Edit

                                    </a>

                                    <a href="/delete-research/<%= research._id %>"
                                        onclick="return confirm('Are you sure you want to delete this research?')"
                                        class="btn btn-danger btn-sm">

                                        Delete

                                    </a>

                                </div>

                            </div>

                        </div>

                    </div>

                <% }) %>

            </div>

        <% } %>

    </div>

    <!-- FOOTER -->

    <%- include("partials/footer") %>

</body>

</html>
<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("partials/head", { pageTitle: "Dashboard | ResearchHub" }) %>
</head>

<body>

    <%- include("partials/navbar", { activePage: "dashboard" }) %>

    <div class="container mt-5 mb-5">

        <!-- Welcome Banner -->

        <div class="p-5 rounded-4 shadow-sm text-white mb-5 reveal in-view"
            style="background:linear-gradient(135deg,#064E3B,#0F766E,#14B8A6);">

            <h1 class="fw-bold">
                Welcome, <%= user.fullName %> 👋
            </h1>

            <p class="fs-5 mt-3 mb-1">
                <strong>Department:</strong>
                <%= user.department %>
            </p>

            <p class="fs-5">
                <strong>Degree:</strong>
                <%= user.degreeLevel %>
            </p>

            <p class="mb-0">
                Manage your uploaded research and contribute to the university repository.
            </p>

        </div>

        <!-- Summary Cards -->

        <div class="row g-4 mb-5">

            <div class="col-md-4">

                <div class="card dashboard-card text-center p-4 reveal reveal-delay-1 in-view">

                    <h2 class="text-primary fw-bold">
                        <%= researches.length %>
                    </h2>

                    <h5>My Research</h5>

                </div>

            </div>

            <div class="col-md-4">

                <div class="card dashboard-card text-center p-4 reveal reveal-delay-2 in-view">

                    <h4 class="text-success fw-bold">
                        <%= user.department %>
                    </h4>

                    <h5>Department</h5>

                </div>

            </div>

            <div class="col-md-4">

                <div class="card dashboard-card text-center p-4 reveal reveal-delay-3 in-view">

                    <h4 class="text-warning fw-bold">
                        <%= user.degreeLevel %>
                    </h4>

                    <h5>Degree Level</h5>

                </div>

            </div>

        </div>

        <!-- Buttons -->

        <div class="mb-5">

            <a href="/upload-research" class="btn btn-warning btn-lg me-3">
                📤 Upload Research
            </a>

            <a href="/researches" class="btn btn-success btn-lg">
                📚 Browse Repository
            </a>

        </div>

        <hr class="mb-5">

        <!-- Uploaded Research -->

        <h3 class="fw-bold text-success mb-4 section-title">

            📚 My Uploaded Research

        </h3>

        <% if(researches.length===0){ %>

            <div class="alert alert-info">

                You haven't uploaded any research yet.

            </div>

        <% } else { %>

            <div class="row">

                <% researches.forEach((research, i) => { %>

                    <div class="col-lg-6 mb-4">

                        <div class="card research-card h-100 reveal <%= i % 2 === 0 ? 'reveal-delay-1' : 'reveal-delay-2' %>">

                            <div class="card-header-strip"></div>

                            <div class="card-body">

                                <h4 class="fw-bold">

                                    <%= research.title %>

                                </h4>

                                <p class="text-muted">

                                    <%= research.department %> • <span class="badge-degree"><%= research.degreeLevel %></span>

                                </p>

                                <p>

                                    <strong>Student:</strong>

                                    <%= research.studentName %>

                                </p>

                                <p>

                                    <strong>Supervisor:</strong>

                                    <%= research.supervisor %>

                                </p>

                                <p>

                                    <strong>Year:</strong>

                                    <%= research.year %>

                                </p>

                                <hr>

                                <div class="d-flex gap-2 flex-wrap">

                                    <a href="/uploads/<%= research.pdfFile %>"
                                        target="_blank"
                                        class="btn btn-success btn-sm">

                                        View PDF

                                    </a>

                                    <a href="/edit-research/<%= research._id %>"
                                        class="btn btn-warning btn-sm">

                                        Edit

                                    </a>

                                    <a href="/delete-research/<%= research._id %>"
                                        onclick="return confirm('Are you sure you want to delete this research?')"
                                        class="btn btn-danger btn-sm">

                                        Delete

                                    </a>

                                </div>

                            </div>

                        </div>

                    </div>

                <% }) %>

            </div>

        <% } %>

    </div>

    <%- include("partials/footer") %>

    <%- include("partials/scripts") %>

</body>

</html>

<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("partials/head", { pageTitle: "Register | ResearchHub" }) %>
</head>

<body>

    <%- include("partials/navbar", { activePage: "register" }) %>

    <section class="py-5">

        <div class="container">

            <div class="row justify-content-center">

                <div class="col-md-10 col-lg-8">

                    <div class="card auth-card reveal in-view">

                        <div class="row g-0">

                            <div class="col-md-4 d-none d-md-flex auth-banner flex-column justify-content-center">
                                <h2>Join ResearchHub 🎓</h2>
                                <p class="mb-0 opacity-75">
                                    Create an account to upload your thesis, browse past
                                    research, and find your own research gap.
                                </p>
                            </div>

                            <div class="col-md-8">

                                <div class="p-4 p-md-5">

                                    <h2 class="text-center mb-4 d-md-none">ResearchHub Registration</h2>
                                    <h4 class="fw-bold mb-4 d-none d-md-block">Create Account</h4>

                                    <% if (typeof error !== "undefined" && error) { %>
                                        <div class="alert alert-danger" role="alert">
                                            ⚠ <%= error %>
                                        </div>
                                    <% } %>

                                    <form action="/register" method="POST">

                                        <div class="row">

                                            <div class="col-md-6 mb-3">
                                                <label class="form-label">Full Name</label>
                                                <input type="text"
                                                       name="fullName"
                                                       class="form-control"
                                                       value="<%= formData.fullName || '' %>"
                                                       placeholder="Full Name"
                                                       required>
                                            </div>

                                            <div class="col-md-6 mb-3">
                                                <label class="form-label">Registration No.</label>
                                                <input type="text"
                                                       name="regNo"
                                                       class="form-control"
                                                       value="<%= formData.regNo || '' %>"
                                                       placeholder="Registration Number"
                                                       required>
                                            </div>

                                        </div>

                                        <div class="mb-3">
                                            <label class="form-label">Email</label>
                                            <input type="email"
                                                   name="email"
                                                   class="form-control"
                                                   value="<%= formData.email || '' %>"
                                                   placeholder="you@example.com"
                                                   required>
                                        </div>

                                        <div class="row">

                                            <div class="col-md-6 mb-3">
                                                <label class="form-label">Department</label>
                                                <select name="department" class="form-select">
                                                    <option <%= formData.department === "Computer Science" ? "selected" : "" %>>Computer Science</option>
                                                    <option <%= formData.department === "Information Technology" ? "selected" : "" %>>Information Technology</option>
                                                    <option <%= formData.department === "Software Engineering" ? "selected" : "" %>>Software Engineering</option>
                                                    <option <%= formData.department === "Management Sciences" ? "selected" : "" %>>Management Sciences</option>
                                                </select>
                                            </div>

                                            <div class="col-md-6 mb-3">
                                                <label class="form-label">Degree Level</label>
                                                <select name="degreeLevel" class="form-select">
                                                    <option <%= formData.degreeLevel === "BS" ? "selected" : "" %>>BS</option>
                                                    <option <%= formData.degreeLevel === "MS" ? "selected" : "" %>>MS</option>
                                                    <option <%= formData.degreeLevel === "PhD" ? "selected" : "" %>>PhD</option>
                                                </select>
                                            </div>

                                        </div>

                                        <div class="mb-4">
                                            <label class="form-label">Password</label>
                                            <input type="password"
                                                   name="password"
                                                   class="form-control"
                                                   placeholder="••••••••"
                                                   required>
                                        </div>

                                        <button class="btn btn-primary w-100 py-2">
                                            Register
                                        </button>

                                    </form>

                                    <p class="text-center text-muted mt-4 mb-0">
                                        Already have an account?
                                        <a href="/login" class="fw-semibold">Login</a>
                                    </p>

                                </div>

                            </div>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </section>

    <%- include("partials/footer") %>

    <%- include("partials/scripts") %>

</body>
</html>

<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("partials/head", { pageTitle: "Login | ResearchHub" }) %>
</head>

<body>

    <%- include("partials/navbar", { activePage: "login" }) %>

    <section class="d-flex align-items-center" style="min-height: 80vh;">

        <div class="container">

            <div class="row justify-content-center">

                <div class="col-md-9 col-lg-7">

                    <div class="card auth-card reveal in-view">

                        <div class="row g-0">

                            <div class="col-md-5 d-none d-md-flex auth-banner flex-column justify-content-center">
                                <h2>Welcome Back 👋</h2>
                                <p class="mb-0 opacity-75">
                                    Log in to manage your research, browse the repository,
                                    and contribute to ResearchHub.
                                </p>
                            </div>

                            <div class="col-md-7">

                                <div class="p-4 p-md-5">

                                    <h2 class="text-center mb-4 d-md-none">Student Login</h2>
                                    <h4 class="fw-bold mb-4 d-none d-md-block">Sign In</h4>

                                    <% if (typeof error !== "undefined" && error) { %>
                                        <div class="alert alert-danger" role="alert">
                                            ⚠ <%= error %>
                                        </div>
                                    <% } %>

                                    <form action="/login" method="POST">

                                        <div class="mb-3">
                                            <label class="form-label">Email</label>
                                            <input
                                                type="email"
                                                name="email"
                                                class="form-control"
                                                placeholder="you@example.com"
                                                required
                                            >
                                        </div>

                                        <div class="mb-4">
                                            <label class="form-label">Password</label>
                                            <input
                                                type="password"
                                                name="password"
                                                class="form-control"
                                                placeholder="••••••••"
                                                required
                                            >
                                        </div>

                                        <button class="btn btn-primary w-100 py-2">
                                            Login
                                        </button>

                                    </form>

                                    <p class="text-center text-muted mt-4 mb-0">
                                        Don't have an account?
                                        <a href="/register" class="fw-semibold">Register</a>
                                    </p>

                                </div>

                            </div>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </section>

    <%- include("partials/footer") %>

    <%- include("partials/scripts") %>

</body>
</html>

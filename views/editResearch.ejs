<!DOCTYPE html>
<html lang="en">
<head>

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Edit Research</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <link rel="stylesheet" href="/css/style.css">

</head>

<body>

<!-- Navbar -->

<nav class="navbar navbar-expand-lg navbar-dark shadow">

    <div class="container">

        <a class="navbar-brand fw-bold" href="/">
            🔬 ResearchHub
        </a>

        <a href="/researches" class="btn btn-light">
            ← Back
        </a>

    </div>

</nav>

<!-- Hero -->

<section class="hero-dashboard">

    <div class="container text-center">

        <h1 class="display-5 fw-bold">

            ✏ Edit Research

        </h1>

        <p class="lead">

            Update your uploaded research details

        </p>

    </div>

</section>

<!-- Form -->

<div class="container my-5">

<div class="card shadow-lg border-0">

<div class="card-body p-4">

<form action="/edit-research/<%= research._id %>" method="POST">

<div class="mb-3">

<label class="form-label">

Research Title

</label>

<input
type="text"
name="title"
class="form-control"
value="<%= research.title %>"
required>

</div>

<div class="mb-3">

<label class="form-label">

Student Name

</label>

<input
type="text"
name="studentName"
class="form-control"
value="<%= research.studentName %>"
required>

</div>

<div class="mb-3">

<label class="form-label">

Department

</label>

<input
type="text"
name="department"
class="form-control"
value="<%= research.department %>"
required>

</div>

<div class="mb-3">

<label class="form-label">

Degree Level

</label>

<input
type="text"
name="degreeLevel"
class="form-control"
value="<%= research.degreeLevel %>"
required>

</div>

<div class="mb-3">

<label class="form-label">

Year

</label>

<input
type="text"
name="year"
class="form-control"
value="<%= research.year %>"
required>

</div>

<div class="mb-3">

<label class="form-label">

Supervisor

</label>

<input
type="text"
name="supervisor"
class="form-control"
value="<%= research.supervisor %>"
required>

</div>

<div class="mb-3">

<label class="form-label">

Abstract

</label>

<textarea
name="abstract"
rows="5"
class="form-control"
required><%= research.abstract %></textarea>

</div>

<div class="mb-3">

<label class="form-label">

Research Gap

</label>

<textarea
name="researchGap"
rows="4"
class="form-control"><%= research.researchGap %></textarea>

</div>

<button class="btn btn-warning">

💾 Update Research

</button>

</form>

</div>

</div>

</div>

</body>

</html>
<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("partials/head", { pageTitle: "Edit Research | ResearchHub" }) %>
</head>

<body>

    <%- include("partials/navbar") %>

    <section class="hero-dashboard hero-compact">

        <div class="container text-center">

            <h1 class="fw-bold">✏️ Edit Research</h1>

            <p class="lead mb-0">Update the details of this research entry</p>

        </div>

    </section>

    <div class="container my-5">

        <div class="row justify-content-center">

            <div class="col-lg-8">

                <div class="card shadow-lg border-0 reveal in-view">

                    <div class="card-body p-4 p-md-5">

                        <form action="/edit-research/<%= research._id %>" method="POST">

                            <div class="mb-3">
                                <label class="form-label">Research Title</label>
                                <input class="form-control" type="text" name="title"
                                    value="<%= research.title %>" required>
                            </div>

                            <div class="row">

                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Student Name</label>
                                    <input class="form-control" type="text" name="studentName"
                                        value="<%= research.studentName %>" required>
                                </div>

                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Department</label>
                                    <input class="form-control" type="text" name="department"
                                        value="<%= research.department %>" required>
                                </div>

                            </div>

                            <div class="row">

                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Degree Level</label>
                                    <select class="form-select" name="degreeLevel">
                                        <option <%= research.degreeLevel === "BS" ? "selected" : "" %>>BS</option>
                                        <option <%= research.degreeLevel === "MS" ? "selected" : "" %>>MS</option>
                                        <option <%= research.degreeLevel === "PhD" ? "selected" : "" %>>PhD</option>
                                    </select>
                                </div>

                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Year</label>
                                    <input class="form-control" type="text" name="year"
                                        value="<%= research.year %>" required>
                                </div>

                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Supervisor</label>
                                    <input class="form-control" type="text" name="supervisor"
                                        value="<%= research.supervisor %>" required>
                                </div>

                            </div>

                            <div class="mb-3">
                                <label class="form-label">Abstract</label>
                                <textarea class="form-control" name="abstract" rows="4" required><%= research.abstract %></textarea>
                            </div>

                            <div class="mb-4">
                                <label class="form-label">Research Gap</label>
                                <textarea class="form-control" name="researchGap" rows="3"><%= research.researchGap %></textarea>
                            </div>

                            <div class="d-flex gap-2">

                                <button class="btn btn-primary flex-grow-1 py-2">
                                    💾 Save Changes
                                </button>

                                <a href="/researches" class="btn btn-outline-secondary py-2">
                                    Cancel
                                </a>

                            </div>

                        </form>

                    </div>

                </div>

            </div>

        </div>

    </div>

    <%- include("partials/footer") %>

    <%- include("partials/scripts") %>

</body>

</html>

<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("partials/head", { pageTitle: "Upload Research | ResearchHub" }) %>
</head>

<body>

    <%- include("partials/navbar", { activePage: "upload" }) %>

    <section class="hero-dashboard hero-compact">

        <div class="container text-center">

            <h1 class="fw-bold">📤 Upload Research</h1>

            <p class="lead mb-0">
                Share your approved thesis and help build the university repository
            </p>

        </div>

    </section>

    <div class="container my-5">

        <div class="row justify-content-center">

            <div class="col-lg-8">

                <div class="card shadow-lg border-0 reveal in-view">

                    <div class="card-body p-4 p-md-5">

                        <% if (typeof error !== "undefined" && error) { %>
                            <div class="alert alert-danger" role="alert">
                                ⚠ <%= error %>
                            </div>
                        <% } %>

                        <form action="/upload-research" method="POST" enctype="multipart/form-data">

                            <div class="mb-3">
                                <label class="form-label">Research Title</label>
                                <input class="form-control" type="text" name="title"
                                    value="<%= formData.title || '' %>"
                                    placeholder="e.g. AI-Based Software Quality Improvement" required>
                            </div>

                            <div class="row">

                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Student Name</label>
                                    <input class="form-control" type="text" name="studentName"
                                        value="<%= formData.studentName || '' %>"
                                        placeholder="Student Name" required>
                                </div>

                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Department</label>
                                    <input class="form-control" type="text" name="department"
                                        value="<%= formData.department || '' %>"
                                        placeholder="Department" required>
                                </div>

                            </div>

                            <div class="row">

                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Degree Level</label>
                                    <select class="form-select" name="degreeLevel">
                                        <option <%= formData.degreeLevel === "BS" ? "selected" : "" %>>BS</option>
                                        <option <%= formData.degreeLevel === "MS" ? "selected" : "" %>>MS</option>
                                        <option <%= formData.degreeLevel === "PhD" ? "selected" : "" %>>PhD</option>
                                    </select>
                                </div>

                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Year</label>
                                    <input class="form-control" type="text" name="year"
                                        value="<%= formData.year || '' %>"
                                        placeholder="2026" required>
                                </div>

                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Supervisor</label>
                                    <input class="form-control" type="text" name="supervisor"
                                        value="<%= formData.supervisor || '' %>"
                                        placeholder="Supervisor Name" required>
                                </div>

                            </div>

                            <div class="mb-3">
                                <label class="form-label">Abstract</label>
                                <textarea class="form-control" name="abstract" rows="4"
                                    placeholder="Brief abstract of your research" required><%= formData.abstract || '' %></textarea>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Research Gap</label>
                                <textarea class="form-control" name="researchGap" rows="3"
                                    placeholder="What gap did you identify?"><%= formData.researchGap || '' %></textarea>
                            </div>

                            <div class="mb-4">
                                <label class="form-label">Research PDF</label>
                                <input class="form-control" type="file" name="pdf" accept="application/pdf" required>
                                <div class="form-text">PDF only, max 20MB.</div>
                            </div>

                            <button class="btn btn-primary w-100 py-2">
                                📤 Upload Research
                            </button>

                        </form>

                    </div>

                </div>

            </div>

        </div>

    </div>

    <%- include("partials/footer") %>

    <%- include("partials/scripts") %>

</body>
</html>

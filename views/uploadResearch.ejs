<!DOCTYPE html>
<html>
<head>
    <title>Upload Research</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<!-- NAVBAR -->

    <%- include("partials/navbar") %>

<div class="container mt-5">

<h2>Upload Research</h2>

<form action="/upload-research" method="POST" enctype="multipart/form-data">

    <input class="form-control mb-3" type="text" name="title" placeholder="Research Title">

    <input class="form-control mb-3" type="text" name="studentName" placeholder="Student Name">

    <input class="form-control mb-3" type="text" name="department" placeholder="Department">

    <select class="form-select mb-3" name="degreeLevel">
        <option>BS</option>
        <option>MS</option>
        <option>PhD</option>
    </select>

    <input class="form-control mb-3" type="text" name="year" placeholder="Year">

    <input class="form-control mb-3" type="text" name="supervisor" placeholder="Supervisor Name">

    <textarea class="form-control mb-3" name="abstract" placeholder="Abstract"></textarea>

    <textarea class="form-control mb-3" name="researchGap" placeholder="Research Gap"></textarea>

    <input class="form-control mb-3" type="file" name="pdf">

    <button class="btn btn-primary">
        Upload Research
    </button>

</form>

</div>

<!-- FOOTER -->
    <!-- ========================= -->

    <%- include("partials/footer") %>

</body>
</html>
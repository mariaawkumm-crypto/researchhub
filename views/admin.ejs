<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("partials/head", { pageTitle: "Admin Panel | ResearchHub" }) %>
</head>

<body>

    <%- include("partials/navbar", { activePage: "admin" }) %>

    <section class="hero-dashboard hero-compact">

        <div class="container text-center">

            <h1 class="fw-bold">👨‍💼 Admin Dashboard</h1>

            <p class="lead mb-0">
                Oversee students and manage the university research repository
            </p>

        </div>

    </section>

    <div class="container my-5">

        <div class="row mb-5 g-4">

            <div class="col-md-6">

                <div class="card dashboard-card text-center p-4 reveal reveal-delay-1 in-view">

                    <h2><%= users.length %></h2>

                    <p class="mb-0">Total Students</p>

                </div>

            </div>

            <div class="col-md-6">

                <div class="card dashboard-card text-center p-4 reveal reveal-delay-2 in-view">

                    <h2><%= researches.length %></h2>

                    <p class="mb-0">Total Research</p>

                </div>

            </div>

        </div>

        <h3 class="mb-4 section-title">📚 All Uploaded Research</h3>

        <div class="table-wrap reveal in-view">

            <table class="table table-hover mb-0">

                <thead>

                    <tr>
                        <th>Title</th>
                        <th>Student</th>
                        <th>Department</th>
                        <th>Year</th>
                        <th>Action</th>
                    </tr>

                </thead>

                <tbody>

                    <% if (researches.length === 0) { %>

                        <tr>
                            <td colspan="5" class="text-center text-muted py-4">
                                No research uploaded yet.
                            </td>
                        </tr>

                    <% } %>

                    <% researches.forEach(research => { %>

                        <tr>

                            <td><%= research.title %></td>

                            <td><%= research.studentName %></td>

                            <td><%= research.department %></td>

                            <td><%= research.year %></td>

                            <td>

                                <a href="/uploads/<%= research.pdfFile %>"
                                    target="_blank"
                                    class="btn btn-success btn-sm me-1">
                                    View
                                </a>

                                <a href="/delete-research/<%= research._id %>"
                                    class="btn btn-danger btn-sm"
                                    onclick="return confirm('Delete this research?')">
                                    Delete
                                </a>

                            </td>

                        </tr>

                    <% }) %>

                </tbody>

            </table>

        </div>

    </div>

    <%- include("partials/footer") %>

    <%- include("partials/scripts") %>

</body>

</html>

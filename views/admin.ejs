<!DOCTYPE html>
<html>

<head>

<title>Admin Panel</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

<link rel="stylesheet" href="/css/style.css">

</head>

<body>

<%- include("partials/navbar") %>

<div class="container mt-5">

<h1 class="mb-4">

👨‍💼 Admin Dashboard

</h1>

<div class="row mb-5">

<div class="col-md-6">

<div class="card dashboard-card text-center p-4">

<h2>

<%= users.length %>

</h2>

<p>Total Students</p>

</div>

</div>

<div class="col-md-6">

<div class="card dashboard-card text-center p-4">

<h2>

<%= researches.length %>

</h2>

<p>Total Research</p>

</div>

</div>

</div>

<h3 class="mb-3">

📚 All Uploaded Research

</h3>

<table class="table table-bordered table-hover">

<thead>

<tr>

<th>Title</th>

<th>Student</th>

<th>Department</th>

<th>Year</th>

<th>Action</th>

</tr>

</thead>

<tbody>

<% researches.forEach(research=>{ %>

<tr>

<td><%= research.title %></td>

<td><%= research.studentName %></td>

<td><%= research.department %></td>

<td><%= research.year %></td>

<td>

<a href="/delete-research/<%= research._id %>"

class="btn btn-danger btn-sm"

onclick="return confirm('Delete this research?')">

Delete

</a>

</td>

</tr>

<% }) %>

</tbody>

</table>

</div>

<%- include("partials/footer") %>

</body>

</html>
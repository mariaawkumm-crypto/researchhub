<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("partials/head", { pageTitle: "ResearchHub | Digital Research Repository" }) %>
</head>

<body>

    <%- include("partials/navbar", { activePage: "home" }) %>

    <!-- ========================= -->
    <!-- HERO SECTION -->
    <!-- ========================= -->

    <section class="hero-dashboard">

        <div class="container">

            <div class="row align-items-center">

                <!-- LEFT SIDE -->

                <div class="col-lg-6">

                    <span class="badge bg-light text-success px-3 py-2 mb-3 fs-6">
                        📚 Digital Research Repository
                    </span>

                    <h1 class="display-3 fw-bold mt-3">
                        Discover Existing <br>
                        Research
                    </h1>

                    <p class="lead mt-4">
                        A Digital Repository for BS, MS &amp; PhD Students.
                    </p>

                    <p class="mb-4">
                        Explore previous research, identify research gaps,
                        and upload your final year projects &amp; thesis.
                    </p>

                    <form action="/researches" method="GET">

                        <div class="input-group search-box">

                            <input
                                type="text"
                                class="form-control"
                                name="search"
                                placeholder="Search by Title, Student, Department or Supervisor..."
                                required>

                            <button class="btn btn-warning fw-bold">
                                🔍 Search
                            </button>

                        </div>

                    </form>

                    <div class="mt-4 hero-cta">

                        <a href="/upload-research" class="btn btn-warning btn-lg me-3">
                            Upload Research
                        </a>

                        <a href="/researches" class="btn btn-light btn-lg">
                            Browse Repository
                        </a>

                    </div>

                </div>

                <!-- RIGHT SIDE -->

                <div class="col-lg-6 text-center mt-5 mt-lg-0">

                    <img src="/images/research-hero.png" class="img-fluid hero-image" alt="Research illustration">

                </div>

            </div>

        </div>

    </section>

    <!-- ========================= -->
    <!-- OVERVIEW CARDS -->
    <!-- ========================= -->

    <div class="container mt-5">

        <div class="row g-4">

            <div class="col-md-3">
                <div class="card dashboard-card text-center reveal reveal-delay-1">
                    <div class="card-body">
                        <h2 class="counter" data-target="<%= stats.totalDepartments %>">0</h2>
                        <p>Total Departments</p>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card dashboard-card text-center reveal reveal-delay-2">
                    <div class="card-body">
                        <h2 class="counter" data-target="<%= stats.totalResearch %>">0</h2>
                        <p>Total Research</p>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card dashboard-card text-center reveal reveal-delay-3">
                    <div class="card-body">
                        <h2 class="counter" data-target="<%= stats.bsResearch %>">0</h2>
                        <p>BS Research</p>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card dashboard-card text-center reveal reveal-delay-4">
                    <div class="card-body">
                        <h2 class="counter" data-target="<%= stats.advancedResearch %>">0</h2>
                        <p>MS / PhD Research</p>
                    </div>
                </div>
            </div>

        </div>

    </div>

    <!-- ========================= -->
    <!-- DEPARTMENTS -->
    <!-- ========================= -->

    <div class="container mt-5">

        <h2 class="text-center fw-bold mb-5 section-title-wrap">
            <span class="section-title">Departments Overview</span>
        </h2>

        <% if (departments.length === 0) { %>

            <div class="alert alert-info text-center">
                No research has been uploaded yet. Be the first to contribute!
            </div>

        <% } else { %>

            <div class="row g-4">

                <% departments.forEach((dept, i) => { %>

                    <div class="col-md-3">
                        <div class="card dept-card reveal reveal-delay-<%= (i % 4) + 1 %>">
                            <div class="card-body">
                                <h5><%= dept.icon %> <%= dept.name %></h5>
                                <p class="text-muted mb-0">
                                    <%= dept.count %> Research Paper<%= dept.count === 1 ? '' : 's' %>
                                </p>
                            </div>
                        </div>
                    </div>

                <% }) %>

            </div>

        <% } %>

    </div>

    <!-- ========================= -->
    <!-- WHY USE RESEARCHHUB -->
    <!-- ========================= -->

    <div class="container mt-5 mb-5">

        <h2 class="text-center fw-bold mb-5 section-title-wrap">
            <span class="section-title">Why Use ResearchHub?</span>
        </h2>

        <div class="row g-4">

            <div class="col-md-4">
                <div class="card dashboard-card text-center p-4 h-100 reveal">
                    <h1>📚</h1>
                    <h4 class="mt-3">Avoid Topic Repetition</h4>
                    <p class="mb-0">
                        Search previous university research before selecting your thesis topic.
                    </p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card dashboard-card text-center p-4 h-100 reveal reveal-delay-1">
                    <h1>🔍</h1>
                    <h4 class="mt-3">Find Research Gaps</h4>
                    <p class="mb-0">
                        Explore existing studies and discover opportunities for future research.
                    </p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card dashboard-card text-center p-4 h-100 reveal reveal-delay-2">
                    <h1>📤</h1>
                    <h4 class="mt-3">Share Your Research</h4>
                    <p class="mb-0">
                        Upload your approved thesis so future students can build on your work.
                    </p>
                </div>
            </div>

        </div>

    </div>

    <!-- ========================= -->
    <!-- CTA BANNER -->
    <!-- ========================= -->

    <div class="container mb-5">

        <div class="p-5 rounded-4 text-center text-white reveal"
            style="background:linear-gradient(135deg,#064E3B,#0F766E,#14B8A6);">

            <h2 class="fw-bold mb-3">Ready to explore or share your research?</h2>

            <p class="lead mb-4">Join ResearchHub today and be part of the academic community.</p>

            <a href="/register" class="btn btn-warning btn-lg fw-bold">Get Started</a>

        </div>

    </div>

    <%- include("partials/footer") %>

    <%- include("partials/scripts") %>

</body>
</html>

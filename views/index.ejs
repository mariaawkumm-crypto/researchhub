<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>ResearchHub | Digital Research Repository</title>

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />

    <link rel="stylesheet" href="/css/style.css" />
  </head>

  <body>
    <!-- ========================= -->
    <!-- NAVBAR -->
    <!-- ========================= -->

    <%- include("partials/navbar") %>

    <!-- ========================= -->
    <!-- HERO SECTION -->
    <!-- ========================= -->

    <!-- ========================= -->
<!-- HERO SECTION -->
<!-- ========================= -->

<section class="hero-dashboard">

<div class="container">

<div class="row align-items-center">

    <!-- LEFT SIDE -->

    <div class="col-lg-6">

        <span class="badge bg-light text-success px-3 py-2 mb-3 fs-6">
            📚 Digital Research Repository
        </span>

        <h1 class="display-3 fw-bold mt-3">
            Discover Existing <br>
            Research
        </h1>

        <p class="lead mt-4">
            A Digital Repository for BS, MS & PhD Students.
        </p>

        <p class="mb-4">

            Explore previous research, identify research gaps,
            and upload your final year projects & thesis.

        </p>

        <form action="/researches" method="GET">

            <div class="input-group search-box">

                <input
                type="text"
                class="form-control"
                name="search"
                placeholder="Search by Title, Student, Department or Supervisor..."
                required>

                <button class="btn btn-warning fw-bold">

                    🔍 Search

                </button>

            </div>

        </form>

        <div class="mt-4">

            <a href="/upload-research"
            class="btn btn-warning btn-lg me-3">

                Upload Research

            </a>

            <a href="/researches"
            class="btn btn-light btn-lg">

                Browse Repository

            </a>

        </div>

    </div>

    <!-- RIGHT SIDE -->

    <div class="col-lg-6 text-center mt-5 mt-lg-0">

        <img
        src="/images/research-hero.png"
        class="img-fluid hero-image">

    </div>

</div>

</div>

</section>

    <!-- ========================= -->
    <!-- OVERVIEW CARDS -->
    <!-- ========================= -->

    <div class="container mt-5">
      <div class="row g-4">
        <div class="col-md-3">
          <div class="card dashboard-card text-center">
            <div class="card-body">
              <h2>12</h2>

              <p>Total Departments</p>
            </div>
          </div>
        </div>

        <div class="col-md-3">
          <div class="card dashboard-card text-center">
            <div class="card-body">
              <h2>58</h2>

              <p>Total Research</p>
            </div>
          </div>
        </div>

        <div class="col-md-3">
          <div class="card dashboard-card text-center">
            <div class="card-body">
              <h2>40</h2>

              <p>BS Research</p>
            </div>
          </div>
        </div>

        <div class="col-md-3">
          <div class="card dashboard-card text-center">
            <div class="card-body">
              <h2>18</h2>

              <p>MS / PhD Research</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- ========================= -->
    <!-- DEPARTMENTS -->
    <!-- ========================= -->

    <div class="container mt-5">
      <h2 class="text-center fw-bold mb-4">Departments Overview</h2>

      <div class="row g-4">
        <div class="col-md-3">
          <div class="card dept-card">
            <div class="card-body">
              <h5>💻 Computer Science</h5>
              <p>12 Research Papers</p>
            </div>
          </div>
        </div>

        <div class="col-md-3">
          <div class="card dept-card">
            <div class="card-body">
              <h5>⚙ Software Engineering</h5>
              <p>8 Research Papers</p>
            </div>
          </div>
        </div>

        <div class="col-md-3">
          <div class="card dept-card">
            <div class="card-body">
              <h5>🖥 Information Technology</h5>
              <p>7 Research Papers</p>
            </div>
          </div>
        </div>

        <div class="col-md-3">
          <div class="card dept-card">
            <div class="card-body">
              <h5>📊 Management Sciences</h5>
              <p>10 Research Papers</p>
            </div>
          </div>
        </div>

        <div class="col-md-3">
          <div class="card dept-card">
            <div class="card-body">
              <h5>📚 Education</h5>
              <p>5 Research Papers</p>
            </div>
          </div>
        </div>

        <div class="col-md-3">
          <div class="card dept-card">
            <div class="card-body">
              <h5>📖 English</h5>
              <p>4 Research Papers</p>
            </div>
          </div>
        </div>

        <div class="col-md-3">
          <div class="card dept-card">
            <div class="card-body">
              <h5>➗ Mathematics</h5>
              <p>3 Research Papers</p>
            </div>
          </div>
        </div>

        <div class="col-md-3">
          <div class="card dept-card">
            <div class="card-body">
              <h5>⚛ Physics</h5>
              <p>6 Research Papers</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- ========================= -->
    <!-- WHY USE RESEARCHHUB -->

<div class="container mt-5 mb-5">

    <h2 class="text-center fw-bold mb-5">
        Why Use ResearchHub?
    </h2>

    <div class="row g-4">

        <div class="col-md-4">

            <div class="card dashboard-card text-center p-4 h-100">

                <h1>📚</h1>

                <h4 class="mt-3">Avoid Topic Repetition</h4>

                <p>
                    Search previous university research before selecting your thesis topic.
                </p>

            </div>

        </div>

        <div class="col-md-4">

            <div class="card dashboard-card text-center p-4 h-100">

                <h1>🔍</h1>

                <h4 class="mt-3">Find Research Gaps</h4>

                <p>
                    Explore existing studies and discover opportunities for future research.
                </p>

            </div>

        </div>

        <div class="col-md-4">

            <div class="card dashboard-card text-center p-4 h-100">

                <h1>📤</h1>

                <h4 class="mt-3">Share Your Research</h4>

                <p>
                    Upload your approved thesis to help future students and build the university repository.
                </p>

            </div>

        </div>

    </div>

</div>

    <!-- ========================= -->
    <!-- FOOTER -->
    <!-- ========================= -->

    <%- include("partials/footer") %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>

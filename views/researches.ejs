<!DOCTYPE html>
<html lang="en">
<head>

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Research Repository</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <link rel="stylesheet" href="/css/style.css">

</head>

<body>

<!-- NAVBAR -->
   
    <%- include("partials/navbar") %>

<!-- Header -->

<section class="hero-dashboard">

    <div class="container text-center">

        <h1 class="display-4 fw-bold">
            📚 Research Repository
        </h1>

        <p class="lead">
            Browse Existing Research Before Selecting Your Topic
        </p>

    </div>

</section>

<!-- Search Section -->

<div class="container mt-5">

    <form action="/researches" method="GET">

        <div class="row justify-content-center">

            <div class="col-md-8">

                <div class="input-group shadow">

                    <input
                        type="text"
                        name="search"
                        class="form-control form-control-lg"
                        placeholder="Search by Title, Student, Department or Supervisor..."
                        value="<%= search %>"
                    >

                    <button class="btn btn-primary">

                        🔍 Search

                    </button>

                </div>

            </div>

        </div>

    </form>

</div>

<!-- Research Cards -->

<div class="container my-5">

    <div class="row">

        <% if(researches.length === 0){ %>

            <div class="alert alert-warning text-center">

                <h4>No Research Found</h4>

                <p>Try searching with another keyword.</p>

            </div>

        <% } %>

        <% researches.forEach(research => { %>

            <div class="col-md-6 mb-4">

                <div class="card shadow-lg border-0 h-100">

                    <div class="card-body">

                        <h4 class="fw-bold">
                            <%= research.title %>
                        </h4>

                        <hr>

                        <p>
                            <strong>Student:</strong>
                            <%= research.studentName %>
                        </p>

                        <p>
                            <strong>Department:</strong>
                            <%= research.department %>
                        </p>

                        <p>
                            <strong>Degree:</strong>
                            <%= research.degreeLevel %>
                        </p>

                        <p>
                            <strong>Year:</strong>
                            <%= research.year %>
                        </p>

                        <p>
                            <strong>Supervisor:</strong>
                            <%= research.supervisor %>
                        </p>

                        <p>
                            <strong>Abstract:</strong><br>
                            <%= research.abstract %>
                        </p>

                        <a
                           href="/uploads/<%= research.pdfFile %>"
                           target="_blank"
                           class="btn btn-success">

                           View PDF

                        </a>

                        

                    </div>

                </div>

            </div>

        <% }) %>

    </div>

</div>

<!-- FOOTER -->
    <!-- ========================= -->

    <%- include("partials/footer") %>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>
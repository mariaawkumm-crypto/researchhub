<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("partials/head", { pageTitle: "Repository | ResearchHub" }) %>
</head>

<body>

    <%- include("partials/navbar", { activePage: "repository" }) %>

    <section class="hero-dashboard hero-compact">

        <div class="container text-center">

            <h1 class="fw-bold">📚 Research Repository</h1>

            <p class="lead mb-4">
                Browse past research from BS, MS &amp; PhD students across all departments
            </p>

            <form action="/researches" method="GET" class="search-box d-flex bg-white">

                <input
                    type="text"
                    name="search"
                    value="<%= search %>"
                    placeholder="Search by title, student, department, or supervisor..."
                    class="form-control"
                >

                <button class="btn btn-warning fw-bold">Search</button>

            </form>

        </div>

    </section>

    <div class="container my-5">

        <% if (search) { %>

            <p class="text-muted mb-4">
                Showing results for "<strong><%= search %></strong>" —
                <%= researches.length %> found
                <a href="/researches" class="ms-2">Clear</a>
            </p>

        <% } %>

        <% if (researches.length === 0) { %>

            <div class="alert alert-info text-center">
                No research found<% if (search) { %> matching your search<% } %>.
            </div>

        <% } else { %>

            <div class="row">

                <% researches.forEach((research, i) => { %>

                    <div class="col-lg-6 mb-4">

                        <div class="card research-card h-100 reveal <%= i % 2 === 0 ? 'reveal-delay-1' : 'reveal-delay-2' %>">

                            <div class="card-header-strip"></div>

                            <div class="card-body">

                                <h4 class="fw-bold">
                                    <%= research.title %>
                                </h4>

                                <p class="text-muted mb-2">
                                    <%= research.department %> • <span class="badge-degree"><%= research.degreeLevel %></span>
                                </p>

                                <p><strong>Student:</strong> <%= research.studentName %></p>
                                <p><strong>Supervisor:</strong> <%= research.supervisor %></p>
                                <p><strong>Year:</strong> <%= research.year %></p>

                                <% if (research.abstract) { %>
                                    <p class="text-muted small">
                                        <%= research.abstract.substring(0, 140) %><%= research.abstract.length > 140 ? '...' : '' %>
                                    </p>
                                <% } %>

                                <hr>

                                <div class="d-flex gap-2 flex-wrap">

                                    <a href="/uploads/<%= research.pdfFile %>"
                                        target="_blank"
                                        class="btn btn-success btn-sm">
                                        View PDF
                                    </a>

                                    <% if (typeof user !== "undefined" && user && (user.role === "admin" || (research.userId && research.userId.toString() === user._id.toString()))) { %>

                                        <a href="/edit-research/<%= research._id %>"
                                            class="btn btn-warning btn-sm">
                                            Edit
                                        </a>

                                        <a href="/delete-research/<%= research._id %>"
                                            onclick="return confirm('Are you sure you want to delete this research?')"
                                            class="btn btn-danger btn-sm">
                                            Delete
                                        </a>

                                    <% } %>

                                </div>

                            </div>

                        </div>

                    </div>

                <% }) %>

            </div>

        <% } %>

    </div>

    <%- include("partials/footer") %>

    <%- include("partials/scripts") %>

</body>

</html>
